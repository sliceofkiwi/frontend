<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Working with the HTML Video Element</title>
</head>
<body>
  <h1>Working with the HTML Video Element</h1>
  <video autoplay
    width="500"
    controls
    muted
    poster="xxxxx"
  >
    <source
      src="xxxxx.mp4"
      type="video/mp4"
    >
    <source
      src="xxxxx.webm"
      type="video/webm"
    >
    <source
      src="xxxxx.ogg"
      type="video/ogg"
    >
    <source
      src="xxxxx.mov"
      type="video/quicktime"
    >
  </video>
  <audio
    src="https://freesound.org/s/620004/"
    controls
    muted
    loop
  ></audio>
</body>
</html>
