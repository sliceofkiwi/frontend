<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Working with the HTML Video Element</title>
</head>
<body>
  <h1>Working with the HTML Video Element</h1>
  <video autoplay
    width="500"
    controls
    poster="https://images.pexels.com/photos/2398220/pexels-photo-2398220.jpeg?w=500"
  >
    <source
      src="https://filesamples.com/samples/video/mp4/sample_640x360.mp4"
      type="video/mp4"
    >
    <source
      src="https://filesamples.com/samples/video/webm/sample_640x360.webm"
      type="video/webm"
    >
    <source
      src="https://filesamples.com/samples/video/webm/sample_640x360.ogg"
      type="video/ogg"
    >
    <source
      src="https://filesamples.com/samples/video/webm/sample_640x360.mov"
      type="video/quicktime"
    >
  </video>
<h2>Audio example</h2>
  <audio
    src="https://cdn.pixabay.com/audio/2024/12/08/audio_e451bc94af.mp3"
    controls
    muted
    loop
  ></audio>
</body>
</html>
